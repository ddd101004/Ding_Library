// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "darwin", "darwin-arm64", "linux-musl-openssl-3.0.x", "debian-openssl-1.1.x"]
  previewFeatures = ["fullTextIndex"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  user_id            String    @id @default(uuid())
  username           String
  phone_number       String?   @unique
  hashed_password    String
  phone_verified     Boolean   @default(false)
  verification_code  String?   @db.VarChar(255)
  session_id         String?
  disabled_status    Int?      @default(0)
  disabled_time      DateTime?
  deleted_status     Int?      @default(0)
  deleted_time       DateTime?
  code_send_time          DateTime?
  code_send_count_minute   Int?      @default(0)  // 当前分钟内的发送次数
  code_attempt_count       Int?      @default(0)
  code_locked_until        DateTime?
  create_time        DateTime? @default(now())
  update_time        DateTime  @updatedAt
  operate_time       DateTime?

  nickname String? @db.VarChar(100)

  // 关联 - 智能对话系统
  conversations ChatConversation[]
  folders       PaperFolder[]
  feedbacks     MessageFeedback[]

  // 关联 - 学术搜索系统
  searchHistory SearchHistory[]

  // 关联 - AI伴读系统
  uploadedPapers UserUploadedPaper[]

  @@map("users")
}

// ==================== 学术资源统一数据模型 ====================

/// 论文表 - 统一存储多个数据源的论文元数据信息
model Paper {
  id String @id @default(uuid())

  // 数据源标识
  source    String @db.VarChar(20) // 数据来源: wanfang
  source_id String @db.VarChar(200) // 来源系统的唯一ID

  // 基本信息
  title      String  @db.VarChar(500) // 论文标题
  title_full String? @db.Text // 完整标题
  title_zh   String? @db.VarChar(500) // 中文标题（AMiner等中文源）
  subtitle   String? @db.Text // 副标题

  // 作者信息
  authors      Json? // 作者列表 (JSON数组，统一格式)
  authors_full String? @db.Text // 完整作者信息 (JSON)

  // 出版信息
  publication_name String? // 出版物名称
  publication_type String? // 出版物类型
  publisher        String? // 出版商
  publication_date DateTime? // 出版日期
  publication_year Int? // 出版年份
  volume           String? // 卷号
  issue            String? // 期号

  // 页码信息
  start_page String? // 起始页码
  page_count Int? // 页数

  // 标识符
  issn String? // ISSN
  isbn String? // ISBN
  doi  String? // DOI

  // 内容信息
  abstract      String? @db.Text // 摘要
  abstract_full String? @db.Text // 完整摘要
  abstract_zh   String? @db.Text // 中文摘要（AMiner等）
  subjects      String? @db.Text // 主题词 (JSON数组)
  keywords      Json? // 关键词 (JSON数组，统一格式)
  keywords_zh   Json? // 中文关键词 (JSON数组，AMiner等)
  language      String? // 语言

  // 出版物信息（统一）
  venue      Json? // 出版物信息（AMiner格式：{raw, raw_zh, t}）
  n_citation Int?  @default(0) // 引用数（AMiner等）

  // 分类信息
  document_type String? // 文档类型
  source_type   String? // 来源类型
  content_type  String? // 内容类型

  // 全文信息
  has_fulltext          Boolean @default(false) // 是否有全文
  fulltext_availability Int? // 全文可用性 (0/1)
  fulltext_link         String? @db.Text // 全文链接

  // 额外元数据
  record_info String? @db.Text // 完整记录信息 (JSON)
  bib_entity  String? @db.Text // 书目实体信息 (JSON)
  items       String? @db.Text // 条目数据 (JSON)

  // 系统字段
  sync_status    Int       @default(1) // 同步状态: 1-成功, 0-失败
  sync_time      DateTime  @default(now()) // 同步时间
  create_time    DateTime  @default(now()) // 创建时间
  update_time    DateTime  @updatedAt // 更新时间
  deleted_status Int       @default(0) // 删除状态: 0-正常, 1-已删除
  deleted_time   DateTime? // 删除时间

  // 关联 - 智能对话系统
  citations   MessageCitation[]
  folderItems FolderItem[]

  // 关联 - 用户行为
  searchHistory SearchHistory[]

  @@unique([source, source_id]) // 联合唯一索引：数据源 + 来源ID
  @@index([source])
  @@index([title])
  @@index([title_zh])
  @@index([publication_date])
  @@index([publication_year])
  @@index([has_fulltext])
  @@index([sync_time])
  @@index([language])
  @@index([n_citation])
  @@map("papers")
}

// ==================== 智能学术对话系统相关模型 ====================

/// 对话会话表 - 存储用户的对话会话信息
model ChatConversation {
  conversation_id String  @id @default(uuid()) @db.VarChar(36)
  user_id         String  @db.VarChar(36)
  title           String  @db.VarChar(255)
  model           String  @default("deepseek-v3") @db.VarChar(50)
  is_deep_think   Boolean @default(false)

  // 上下文管理
  context_window Int @default(10) // 上下文窗口大小（消息条数）
  max_tokens     Int @default(64000) // 最大token限制

  // 消息统计（冗余字段，提升查询性能）
  message_count Int @default(0) // 消息总数

  // 论文检索功能开关
  autoSearchPapers Boolean @default(false) @map("auto_search_papers") // 是否自动检索相关论文

  last_message_at DateTime  @default(now())
  create_time     DateTime  @default(now())
  update_time     DateTime  @updatedAt
  deleted_at      DateTime?

  // 关联
  user        User               @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  messages    ChatMessage[]
  citations   MessageCitation[] // 对话关联的论文引用
  folderItems FolderItem[]      // 对话所在的文件夹

  @@index([user_id, last_message_at])
  @@map("chat_conversations")
}

/// 消息表 - 存储对话中的消息内容
model ChatMessage {
  message_id      String @id @default(uuid()) @db.VarChar(36)
  conversation_id String @db.VarChar(36)
  role            String @db.VarChar(20) // "user" | "assistant" | "system"
  content         String @db.LongText
  content_type    String @default("text") @db.VarChar(20) // "text" | "citation" | "image"

  // 消息顺序编号
  message_order Int // 消息在会话中的顺序（从1开始）

  // Token统计
  input_tokens  Int? @default(0)
  output_tokens Int? @default(0)
  total_tokens  Int? @default(0)

  // DeepSeek-R1 深度思考功能
  reasoning_tokens  Int?     @map("reasoning_tokens") // 推理tokens
  reasoning_content String?  @map("reasoning_content") @db.LongText // 推理过程
  cost             Decimal? @db.Decimal(10, 6) // API调用费用
  responseTimeMs   Int?     @map("response_time_ms") // 响应时间 (毫秒)

  // 流式输出状态
  status        String  @default("completed") @db.VarChar(20) // "streaming" | "completed" | "stopped" | "error"
  error_message String? @db.LongText

  // 关联父消息（用于重新生成）
  parent_message_id String? @db.VarChar(36)
  root_message_id   String? @db.VarChar(36)

  create_time DateTime @default(now())
  update_time DateTime @updatedAt

  // 关联
  conversation ChatConversation    @relation(fields: [conversation_id], references: [conversation_id], onDelete: Cascade)
  citations    MessageCitation[]
  feedbacks    MessageFeedback[]

  @@index([conversation_id, message_order])
  @@index([parent_message_id])
  @@index([root_message_id])
  @@fulltext([content])
  @@map("chat_messages")
}

/// 消息引用关系表 - 存储消息与论文的引用关系
/// 支持两种类型: 用户主动引用(user_cited) 和 自动检索关联(auto_related)
model MessageCitation {
  citation_id     String  @id @default(uuid()) @db.VarChar(36)
  message_id      String  @db.VarChar(36)
  paper_id        String  @db.VarChar(36)
  conversation_id String? @db.VarChar(36) // 关联的对话ID，方便查询对话下所有引用的论文

  // 引用类型区分
  citation_type   String   @default("user_cited") @db.VarChar(20) // "user_cited" | "auto_related"
  search_keywords String?  @db.VarChar(500) // 搜索关键词（自动检索时使用）
  relevance_score Decimal? @db.Decimal(5, 4) // 相关度分数（0-1，用于自动检索结果排序）

  // 用户引用相关字段
  citation_order  Int // 引用顺序（在消息中的位置）
  citation_format String? @db.VarChar(20) // "APA" | "MLA" | "Chicago" | "BibTex" | "RIS"
  formatted_text  String? @db.Text // 格式化后的引用文本

  create_time DateTime @default(now())
  update_time DateTime @updatedAt

  // 关联
  message      ChatMessage       @relation(fields: [message_id], references: [message_id], onDelete: Cascade)
  paper        Paper             @relation(fields: [paper_id], references: [id], onDelete: Cascade)
  conversation ChatConversation? @relation(fields: [conversation_id], references: [conversation_id], onDelete: Cascade)

  @@unique([message_id, paper_id])
  @@index([message_id])
  @@index([paper_id])
  @@index([conversation_id])
  @@index([citation_type])
  @@index([conversation_id, citation_type])
  @@map("message_citations")
}


/// 论文文件夹表 - 存储用户创建的论文收藏文件夹
model PaperFolder {
  folder_id   String  @id @default(uuid()) @db.VarChar(36)
  user_id     String  @db.VarChar(36)
  folder_name String  @db.VarChar(100)
  description String? @db.Text
  cover_image String? @db.VarChar(500) // 文件夹封面图 URL

  create_time DateTime @default(now())
  update_time DateTime @updatedAt

  // 关联
  user  User         @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  items FolderItem[]

  @@index([user_id])
  @@map("paper_folders")
}

/// 文件夹内容关联表 - 存储文件夹与各类内容的多对多关系
/// 支持三种内容类型: Paper(第三方数据源论文)、UserUploadedPaper(用户上传论文)、ChatConversation(对话)
/// paper_id、uploaded_paper_id、conversation_id 三选一
model FolderItem {
  item_id   String  @id @default(uuid()) @db.VarChar(36)
  folder_id String  @db.VarChar(36)

  // 三种内容类型 - 三选一
  paper_id          String? @db.VarChar(36) // 第三方数据源论文ID (Paper表)
  uploaded_paper_id String? @db.VarChar(36) // 用户上传论文ID (UserUploadedPaper表)
  conversation_id   String? @db.VarChar(36) // 对话ID (ChatConversation表)

  notes String? @db.Text // 用户备注

  added_at DateTime @default(now())

  create_time DateTime @default(now())
  update_time DateTime @updatedAt

  // 关联
  folder        PaperFolder        @relation(fields: [folder_id], references: [folder_id], onDelete: Cascade)
  paper         Paper?             @relation(fields: [paper_id], references: [id], onDelete: Cascade)
  uploadedPaper UserUploadedPaper? @relation(fields: [uploaded_paper_id], references: [id], onDelete: Cascade)
  conversation  ChatConversation?  @relation(fields: [conversation_id], references: [conversation_id], onDelete: Cascade)

  @@unique([folder_id, paper_id])
  @@unique([folder_id, uploaded_paper_id])
  @@unique([folder_id, conversation_id])
  @@index([folder_id])
  @@index([paper_id])
  @@index([uploaded_paper_id])
  @@index([conversation_id])
  @@map("folder_items")
}

/// 消息反馈表 - 存储用户对消息的反馈
model MessageFeedback {
  feedback_id      String  @id @default(uuid()) @db.VarChar(36)
  message_id       String  @db.VarChar(36)
  user_id          String  @db.VarChar(36)
  feedback_type    String  @db.VarChar(20) // "like" | "dislike" | "copy" | "regenerate"

  create_time DateTime @default(now())
  update_time DateTime @updatedAt

  // 关联
  message ChatMessage @relation(fields: [message_id], references: [message_id], onDelete: Cascade)
  user    User        @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([message_id])
  @@index([user_id])
  @@map("message_feedbacks")
}

// ==================== 学术资源统一数据模型（续）====================



/// 搜索历史表 - 记录用户的搜索行为
model SearchHistory {
  id           String @id @default(uuid())
  user_id      String
  keyword      String @db.VarChar(200)
  search_type  String @db.VarChar(20) // paper, comprehensive
  result_count Int?   @default(0)

  // 关联的结果（使用数据库 UUID）
  paper_id   String?

  deleted_status Int       @default(0) @map("deleted_status") // 删除状态: 0-正常, 1-已删除
  deleted_time   DateTime? @map("deleted_time") // 删除时间
  create_time    DateTime  @default(now())
  update_time    DateTime  @updatedAt

  user    User     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  paper   Paper?   @relation(fields: [paper_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([create_time])
  @@index([user_id, search_type, create_time])
  @@index([user_id, deleted_status])
  @@map("search_history")
}

// ==================== AI伴读功能相关模型 ====================

/// 用户上传论文表 - 存储用户上传的论文文件和解析后的内容
model UserUploadedPaper {
  id String @id @default(uuid())
  userId String @map("user_id")
  title String @db.VarChar(500)

  // 文件信息
  filePath String @map("file_path") @db.VarChar(500)
  fileName String @map("file_name") @db.VarChar(255)
  fileSize BigInt @map("file_size")
  fileType String @map("file_type") @db.VarChar(50)
  mimeType String @map("mime_type") @db.VarChar(100)

  // 解析状态
  parseStatus   String    @default("pending") @map("parse_status") @db.VarChar(20)
  parsedContent String?   @map("parsed_content") @db.LongText
  pageCount     Int?      @map("page_count")
  wordCount     Int?      @map("word_count")
  parseError    String?   @map("parse_error") @db.Text
  parsedAt      DateTime? @map("parsed_at")

  // 时间戳
  createTime DateTime  @default(now()) @map("create_time")
  updateTime DateTime  @updatedAt @map("update_time")
  deletedAt  DateTime? @map("deleted_at")

  // 关联
  user        User         @relation(fields: [userId], references: [user_id], onDelete: Cascade)
  folderItems FolderItem[] // 文件夹关联

  @@index([userId])
  @@index([createTime])
  @@index([parseStatus])
  @@index([deletedAt])
  @@map("user_uploaded_papers")
}
