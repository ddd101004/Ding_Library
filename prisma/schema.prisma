// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "darwin", "darwin-arm64", "linux-musl-openssl-3.0.x", "debian-openssl-1.1.x"]
  previewFeatures = ["fullTextIndex"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  user_id            String    @id @default(uuid())
  username           String
  phone_number       String?   @unique
  hashed_password    String
  phone_verified     Boolean   @default(false)
  company_name       String?
  country            String?
  province           String?
  city               String?
  isp                String?
  verification_code  String?   @db.VarChar(255)
  avatar             String?   @db.VarChar(500)
  session_id         String?
  disabled_status    Int?      @default(0)
  disabled_time      DateTime?
  deleted_status     Int?      @default(0)
  deleted_time       DateTime?
  code_send_time     DateTime?
  code_attempt_count Int?      @default(0)
  code_locked_until  DateTime?
  create_time        DateTime? @default(now())
  update_time        DateTime  @updatedAt
  operate_time       DateTime?

  email    String? @unique @db.VarChar(255)
  nickname String? @db.VarChar(100)

  // 通知设置
  notify_doc_delivery Boolean @default(true) @map("notify_doc_delivery")

  // FastGPT 集成
  fastgpt_root_dataset_id String? @db.VarChar(100) // 用户在 FastGPT 的根知识库 ID

  // 关联 - 智能对话系统
  conversations ChatConversation[]
  folders       PaperFolder[]
  feedbacks     MessageFeedback[]

  // 关联 - 学术搜索系统
  searchHistory SearchHistory[]
  browseHistory BrowseHistory[]
  favorites     Favorite[]

  // 关联 - AI伴读系统
  uploadedPapers      UserUploadedPaper[]
  paperAnnotations    PaperAnnotation[]
  paperReadingRecords PaperReadingRecord[]

  // 关联 - 全文传递
  docDeliveryRequests DocDeliveryRequest[]

  // 关联 - 用户通知
  notifications UserNotification[]

  @@map("users")
}

model Bill {
  id                String    @id @default(uuid())
  user_id           String
  input_content     String    @db.Text // 支持长文本输入
  output_content    String    @db.Text // 支持长文本输出
  reasoning_content String?   @db.Text // 思考过程内容
  input_tokens      Int
  output_tokens     Int
  reasoning_tokens  Int?      @default(0) // 思考过程消耗的 tokens
  total_tokens      Int
  model             String
  type              String
  deleted_status    Int?      @default(0)
  deleted_time      DateTime?
  create_time       DateTime? @default(now())
  update_time       DateTime? @updatedAt

  @@map("bills")
}

model commonConfig {
  id              Int       @id @default(autoincrement())
  label           String
  key             String
  value           String
  type            String
  source          String?   @default("ai-medical")
  disabled_status Int?      @default(0)
  disabled_time   DateTime?
  create_time     DateTime  @default(now())
  update_time     DateTime? @updatedAt

  @@map("common_config")
}

// ==================== 学术资源统一数据模型 ====================

/// 论文表 - 统一存储多个数据源的论文元数据信息
model Paper {
  id String @id @default(uuid())

  // 数据源标识
  source    String @db.VarChar(20) // 数据来源: ebsco, aminer, wanfang
  source_id String @db.VarChar(200) // 来源系统的唯一ID

  // EBSCO 特定标识符（仅 EBSCO 来源使用）
  db_id String? // EBSCO数据库ID (如: aph, lkh)
  an    String? // EBSCO访问号 (Accession Number)

  // 基本信息
  title      String  @db.VarChar(500) // 论文标题
  title_full String? @db.Text // 完整标题
  title_zh   String? @db.VarChar(500) // 中文标题（AMiner等中文源）
  subtitle   String? @db.Text // 副标题

  // 作者信息
  authors      Json? // 作者列表 (JSON数组，统一格式)
  authors_full String? @db.Text // 完整作者信息 (JSON)

  // 出版信息
  publication_name String? // 出版物名称
  publication_type String? // 出版物类型
  publisher        String? // 出版商
  publication_date DateTime? // 出版日期
  publication_year Int? // 出版年份
  volume           String? // 卷号
  issue            String? // 期号

  // 页码信息
  start_page String? // 起始页码
  page_count Int? // 页数

  // 标识符
  issn String? // ISSN
  isbn String? // ISBN
  doi  String? // DOI

  // 内容信息
  abstract      String? @db.Text // 摘要
  abstract_full String? @db.Text // 完整摘要
  abstract_zh   String? @db.Text // 中文摘要（AMiner等）
  subjects      String? @db.Text // 主题词 (JSON数组)
  keywords      Json? // 关键词 (JSON数组，统一格式)
  keywords_zh   Json? // 中文关键词 (JSON数组，AMiner等)
  language      String? // 语言

  // 出版物信息（统一）
  venue      Json? // 出版物信息（AMiner格式：{raw, raw_zh, t}）
  n_citation Int?  @default(0) // 引用数（AMiner等）

  // 分类信息
  document_type String? // 文档类型
  source_type   String? // 来源类型
  content_type  String? // 内容类型

  // 全文信息
  has_fulltext          Boolean @default(false) // 是否有全文
  fulltext_availability Int? // 全文可用性 (0/1)
  fulltext_link         String? @db.Text // 全文链接
  pdf_link              String? @db.Text // PDF链接

  // PDF下载状态
  pdf_downloaded    Boolean   @default(false) // PDF是否已下载
  pdf_file_path     String?   @db.Text // PDF文件存储路径
  pdf_file_size     BigInt? // PDF文件大小(字节)
  pdf_download_time DateTime? // PDF下载时间

  // EBSCO原始数据
  plink           String? @db.Text // EBSCO永久链接
  custom_links    String? @db.Text // 自定义链接 (JSON)
  relevancy_score Int? // 相关性评分

  // 额外元数据
  record_info String? @db.Text // 完整记录信息 (JSON)
  bib_entity  String? @db.Text // 书目实体信息 (JSON)
  items       String? @db.Text // 条目数据 (JSON)

  // 统计信息
  view_count     Int @default(0) // 查看次数
  download_count Int @default(0) // 下载次数

  // 系统字段
  sync_status    Int       @default(1) // 同步状态: 1-成功, 0-失败
  sync_time      DateTime  @default(now()) // 同步时间
  create_time    DateTime  @default(now()) // 创建时间
  update_time    DateTime  @updatedAt // 更新时间
  deleted_status Int       @default(0) // 删除状态: 0-正常, 1-已删除
  deleted_time   DateTime? // 删除时间

  // FastGPT 公共数据集同步状态
  fastgpt_collection_id String?   @db.VarChar(100) // FastGPT 中的 collection ID
  fastgpt_sync_source   String?   @db.VarChar(20) // 同步来源: cron_task, user_search, chat_related
  fastgpt_sync_time     DateTime? // FastGPT 同步时间
  fastgpt_has_fulltext  Boolean   @default(false) // 是否已同步全文到 FastGPT

  // 关联 - 智能对话系统
  citations   MessageCitation[]
  folderItems FolderItem[]

  // 关联 - 用户行为
  searchHistory SearchHistory[]
  browseHistory BrowseHistory[]
  favorites     Favorite[]

  // 关联 - 全文传递
  docDeliveryRequests DocDeliveryRequest[]

  @@unique([source, source_id]) // 联合唯一索引：数据源 + 来源ID
  @@unique([db_id, an]) // EBSCO 特定索引（兼容现有数据）
  @@index([source])
  @@index([title])
  @@index([title_zh])
  @@index([publication_date])
  @@index([publication_year])
  @@index([has_fulltext])
  @@index([pdf_downloaded])
  @@index([sync_time])
  @@index([language])
  @@index([n_citation])
  @@index([fastgpt_collection_id])
  @@map("papers")
}

/// 论文下载日志表 - 记录用户的PDF下载行为
model PaperDownloadLog {
  id String @id @default(uuid())

  // 关联信息
  paper_id String // 论文ID
  user_id  String? // 用户ID (可为空，支持游客下载)

  // 下载信息
  download_type   String // 下载类型: pdf, fulltext
  download_status Int // 下载状态: 1-成功, 0-失败
  fail_reason     String? @db.Text // 失败原因

  // 来源信息
  ip_address String? // IP地址
  user_agent String? @db.Text // User Agent
  referer    String? @db.Text // 来源页面

  // 系统字段
  create_time DateTime @default(now()) // 创建时间
  update_time DateTime @updatedAt // 更新时间

  @@index([paper_id])
  @@index([user_id])
  @@index([create_time])
  @@map("paper_download_logs")
}

/// EBSCO同步日志表 - 记录每次同步任务的执行情况
model EbscoSyncLog {
  id String @id @default(uuid())

  // 同步任务信息
  sync_type     String // 同步类型: papers-论文数据, pdfs-PDF文件
  sync_batch_no String // 批次号

  // 同步参数
  search_query String? @db.Text // 搜索查询条件
  target_count Int? // 目标同步数量

  // 执行结果
  total_count   Int @default(0) // 总处理数量
  success_count Int @default(0) // 成功数量
  fail_count    Int @default(0) // 失败数量
  skip_count    Int @default(0) // 跳过数量

  // 执行状态
  status        Int // 状态: 1-成功, 0-失败, 2-部分成功, 3-进行中
  error_message String? @db.Text // 错误信息

  // 时间信息
  start_time       DateTime  @default(now()) // 开始时间
  end_time         DateTime? // 结束时间
  duration_seconds Int? // 执行时长(秒)

  // 详细日志
  detail_log String? @db.LongText // 详细日志 (JSON)

  // 系统字段
  create_time DateTime @default(now()) // 创建时间
  update_time DateTime @updatedAt // 更新时间

  @@index([sync_type])
  @@index([sync_batch_no])
  @@index([start_time])
  @@map("ebsco_sync_logs")
}

/// EBSCO配置表 - 存储EBSCO相关的配置参数
model EbscoConfig {
  id Int @id @default(autoincrement())

  // 配置信息
  config_key   String  @unique // 配置键
  config_value String  @db.Text // 配置值
  config_type  String // 配置类型: string, number, boolean, json
  description  String? @db.Text // 配置描述

  // 分组和排序
  config_group String @default("general") // 配置分组
  sort_order   Int    @default(0) // 排序

  // 状态
  is_public       Boolean @default(false) // 是否公开 (前端可见)
  disabled_status Int     @default(0) // 禁用状态: 0-启用, 1-禁用

  // 系统字段
  create_time DateTime @default(now()) // 创建时间
  update_time DateTime @updatedAt // 更新时间

  @@index([config_group])
  @@map("ebsco_configs")
}

// ==================== 智能学术对话系统相关模型 ====================

/// 对话会话表 - 存储用户的对话会话信息
model ChatConversation {
  conversation_id String  @id @default(uuid()) @db.VarChar(36)
  user_id         String  @db.VarChar(36)
  title           String  @db.VarChar(255)
  model           String  @default("deepseek-v3") @db.VarChar(50)
  is_deep_think   Boolean @default(false)
  is_pinned       Boolean @default(false)

  // 上下文管理
  context_window Int @default(10) // 上下文窗口大小（消息条数）
  max_tokens     Int @default(64000) // 最大token限制

  // 消息统计（冗余字段，提升查询性能）
  message_count Int @default(0) // 消息总数

  // 论文检索功能开关
  autoSearchPapers Boolean @default(false) @map("auto_search_papers") // 是否自动检索相关论文

  // AI伴读功能扩展字段
  conversationType String  @default("general") @map("conversation_type") @db.VarChar(20) // 对话类型: general-普通对话, paper_reading-论文伴读, folder_rag-文件夹知识库对话
  uploadedPaperId  String? @map("uploaded_paper_id") @db.VarChar(36) // 关联的用户上传论文ID (paper_reading类型使用)
  folderId         String? @map("folder_id") @db.VarChar(36) // 关联的文件夹ID (folder_rag类型使用)
  contextMode      String  @default("auto") @map("context_mode") @db.VarChar(20) // 上下文模式: full_paper-全文, selected_text-选中文本, auto-自动

  last_message_at DateTime  @default(now())
  create_time     DateTime  @default(now())
  update_time     DateTime  @updatedAt
  deleted_at      DateTime?

  // 关联
  user          User               @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  uploadedPaper UserUploadedPaper? @relation(fields: [uploadedPaperId], references: [id], onDelete: SetNull)
  folder        PaperFolder?       @relation(fields: [folderId], references: [folder_id], onDelete: SetNull)
  messages      ChatMessage[]
  citations     MessageCitation[] // 对话关联的论文引用
  folderItems   FolderItem[]      // 文件夹关联

  @@index([user_id, last_message_at])
  @@index([user_id, is_pinned])
  @@index([uploadedPaperId])
  @@index([folderId])
  @@map("chat_conversations")
}

/// 消息表 - 存储对话中的消息内容
model ChatMessage {
  message_id      String @id @default(uuid()) @db.VarChar(36)
  conversation_id String @db.VarChar(36)
  role            String @db.VarChar(20) // "user" | "assistant" | "system"
  content         String @db.LongText
  content_type    String @default("text") @db.VarChar(20) // "text" | "citation" | "image"

  // 消息顺序编号
  message_order Int // 消息在会话中的顺序（从1开始）

  // Token统计
  input_tokens  Int? @default(0)
  output_tokens Int? @default(0)
  total_tokens  Int? @default(0)

  // AI伴读功能扩展字段
  messageType      String   @default("text") @map("message_type") @db.VarChar(20) // 消息类型: text-普通文本, deepthink-深度思考, translate-翻译, summarize-总结, explain-解释
  reasoningTokens  Int?     @map("reasoning_tokens") // 推理tokens
  reasoningContent String?  @map("reasoning_content") @db.LongText // 推理过程
  contextText      String?  @map("context_text") @db.LongText // 引用的论文文本片段
  contextRange     Json?    @map("context_range") // 文本位置信息 {start, end, page}
  cost             Decimal? @db.Decimal(10, 6) // API调用费用
  responseTimeMs   Int?     @map("response_time_ms") // 响应时间 (毫秒)

  // 流式输出状态
  status        String  @default("completed") @db.VarChar(20) // "streaming" | "completed" | "stopped" | "error"
  error_message String? @db.LongText

  // 关联父消息（用于重新生成）
  parent_message_id String? @db.VarChar(36)
  root_message_id   String? @db.VarChar(36)

  create_time DateTime @default(now())
  update_time DateTime @updatedAt

  // 关联
  conversation ChatConversation    @relation(fields: [conversation_id], references: [conversation_id], onDelete: Cascade)
  citations    MessageCitation[]
  feedbacks    MessageFeedback[]
  attachments  MessageAttachment[]

  @@index([conversation_id, message_order])
  @@index([parent_message_id])
  @@index([root_message_id])
  @@fulltext([content])
  @@map("chat_messages")
}

/// 消息引用关系表 - 存储消息与论文的引用关系
/// 支持两种类型: 用户主动引用(user_cited) 和 自动检索关联(auto_related)
model MessageCitation {
  citation_id     String  @id @default(uuid()) @db.VarChar(36)
  message_id      String  @db.VarChar(36)
  paper_id        String  @db.VarChar(36)
  conversation_id String? @db.VarChar(36) // 关联的对话ID，方便查询对话下所有引用的论文

  // 引用类型区分
  citation_type   String   @default("user_cited") @db.VarChar(20) // "user_cited" | "auto_related"
  search_keywords String?  @db.VarChar(500) // 搜索关键词（自动检索时使用）
  relevance_score Decimal? @db.Decimal(5, 4) // 相关度分数（0-1，用于自动检索结果排序）

  // 用户引用相关字段
  citation_order  Int // 引用顺序（在消息中的位置）
  citation_format String? @db.VarChar(20) // "APA" | "MLA" | "Chicago" | "BibTex" | "RIS"
  formatted_text  String? @db.Text // 格式化后的引用文本

  create_time DateTime @default(now())
  update_time DateTime @updatedAt

  // 关联
  message      ChatMessage       @relation(fields: [message_id], references: [message_id], onDelete: Cascade)
  paper        Paper             @relation(fields: [paper_id], references: [id], onDelete: Cascade)
  conversation ChatConversation? @relation(fields: [conversation_id], references: [conversation_id], onDelete: Cascade)

  @@unique([message_id, paper_id])
  @@index([message_id])
  @@index([paper_id])
  @@index([conversation_id])
  @@index([citation_type])
  @@index([conversation_id, citation_type])
  @@map("message_citations")
}

/// 消息附件表 - 存储消息与用户上传文件的关联关系
model MessageAttachment {
  id                String @id @default(uuid()) @db.VarChar(36)
  message_id        String @db.VarChar(36)
  uploaded_paper_id String @db.VarChar(36)

  // 冗余字段 - 提高查询效率，避免多表关联
  file_name String @db.VarChar(255) // 文件名
  file_type String @db.VarChar(50) // 文件类型 (pdf/doc/docx/txt)
  file_size BigInt // 文件大小 (字节)

  // 排序
  attachment_order Int @default(1) // 附件顺序

  create_time DateTime @default(now())

  // 关联
  message       ChatMessage       @relation(fields: [message_id], references: [message_id], onDelete: Cascade)
  uploadedPaper UserUploadedPaper @relation(fields: [uploaded_paper_id], references: [id], onDelete: Cascade)

  @@unique([message_id, uploaded_paper_id])
  @@index([message_id])
  @@index([uploaded_paper_id])
  @@map("message_attachments")
}

/// 论文文件夹表 - 存储用户创建的论文收藏文件夹（同时作为 FastGPT 知识库）
model PaperFolder {
  folder_id   String  @id @default(uuid()) @db.VarChar(36)
  user_id     String  @db.VarChar(36)
  folder_name String  @db.VarChar(100)
  description String? @db.Text
  color       String? @db.VarChar(20) // 文件夹颜色标识
  cover_image String? @db.VarChar(500) // 文件夹封面图 URL
  sort_order  Int     @default(0) // 排序权重

  // FastGPT RAG 知识库集成
  fastgpt_dataset_id String? @db.VarChar(100) // FastGPT 知识库 ID

  create_time DateTime @default(now())
  update_time DateTime @updatedAt

  // 关联
  user          User               @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  items         FolderItem[]
  conversations ChatConversation[] // 关联的文件夹知识库对话

  @@index([user_id, sort_order])
  @@map("paper_folders")
}

/// 文件夹内容关联表 - 存储文件夹与各类内容的多对多关系
/// 支持三种内容类型: Paper(第三方数据源论文)、UserUploadedPaper(用户上传论文)、ChatConversation(对话)
/// paper_id、uploaded_paper_id、conversation_id 三选一
model FolderItem {
  item_id   String  @id @default(uuid()) @db.VarChar(36)
  folder_id String  @db.VarChar(36)

  // 三种内容类型 - 三选一
  paper_id          String? @db.VarChar(36) // 第三方数据源论文ID (Paper表)
  uploaded_paper_id String? @db.VarChar(36) // 用户上传论文ID (UserUploadedPaper表)
  conversation_id   String? @db.VarChar(36) // 对话ID (ChatConversation表)

  notes String? @db.Text // 用户备注

  added_at DateTime @default(now())

  create_time DateTime @default(now())
  update_time DateTime @updatedAt

  // 关联
  folder        PaperFolder        @relation(fields: [folder_id], references: [folder_id], onDelete: Cascade)
  paper         Paper?             @relation(fields: [paper_id], references: [id], onDelete: Cascade)
  uploadedPaper UserUploadedPaper? @relation(fields: [uploaded_paper_id], references: [id], onDelete: Cascade)
  conversation  ChatConversation?  @relation(fields: [conversation_id], references: [conversation_id], onDelete: Cascade)

  @@unique([folder_id, paper_id])
  @@unique([folder_id, uploaded_paper_id])
  @@unique([folder_id, conversation_id])
  @@index([folder_id])
  @@index([paper_id])
  @@index([uploaded_paper_id])
  @@index([conversation_id])
  @@map("folder_items")
}

/// 消息反馈表 - 存储用户对消息的反馈
model MessageFeedback {
  feedback_id      String  @id @default(uuid()) @db.VarChar(36)
  message_id       String  @db.VarChar(36)
  user_id          String  @db.VarChar(36)
  feedback_type    String  @db.VarChar(20) // "like" | "dislike" | "copy" | "regenerate"
  feedback_content String? @db.Text // 详细反馈内容（可选）

  create_time DateTime @default(now())
  update_time DateTime @updatedAt

  // 关联
  message ChatMessage @relation(fields: [message_id], references: [message_id], onDelete: Cascade)
  user    User        @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([message_id])
  @@index([user_id])
  @@map("message_feedbacks")
}

// ==================== 学术资源统一数据模型（续）====================

/// 学者表 - 统一存储多个数据源的学者信息
model Scholar {
  id String @id @default(uuid())

  // 数据源标识
  source    String @db.VarChar(20) // 数据来源: aminer, wanfang, cnki
  source_id String @db.VarChar(200) // 来源系统的唯一ID

  // 基本信息
  name    String  @db.VarChar(200)
  name_zh String? @db.VarChar(200)

  // 机构信息
  orgs        Json? // 机构列表 (JSON数组)
  org_zhs     Json? // 中文机构列表
  position    String? @db.VarChar(200)
  position_zh String? @db.VarChar(200)

  // 个人简介
  bio    String? @db.Text
  bio_zh String? @db.Text
  edu    String? @db.Text
  edu_zh String? @db.Text

  // 研究领域
  interests Json? // 研究兴趣列表
  honor     Json? // 荣誉列表

  // 学术指标
  n_citation Int? @default(0)
  h_index    Int? @default(0)

  // 学者画像 - 结构化数据 (来自 person/figure API)
  edus         Json? // 结构化教育经历 [{school, degree, major, start_date, end_date}]
  works        Json? // 结构化工作经历 [{org, position, start_date, end_date}]
  ai_domain    Json? // AI研究领域 [{name, name_zh, weight}]
  ai_interests Json? // AI研究兴趣 [{name, name_zh, weight}]

  create_time DateTime @default(now())
  update_time DateTime @updatedAt

  // 关联 - 用户行为
  searchHistory SearchHistory[]
  browseHistory BrowseHistory[]
  favorites     Favorite[]

  @@unique([source, source_id])
  @@index([source])
  @@index([name])
  @@index([name_zh])
  @@index([n_citation])
  @@map("scholars")
}

/// 专利表 - 统一存储多个数据源的专利信息
model Patent {
  id String @id @default(uuid())

  // 数据源标识
  source    String @db.VarChar(20) // 数据来源: aminer, wanfang, cnki
  source_id String @db.VarChar(200) // 来源系统的唯一ID

  // 基本信息
  title    String  @db.VarChar(500) // 主标题（优先中文，无中文则英文）
  title_zh String? @db.VarChar(500) // 中文标题
  title_en String? @db.VarChar(500) // 英文标题
  abstract String? @db.Text
  year     Int?

  // 专利标识
  app_num  String? @db.VarChar(100) // 申请号
  pub_num  String? @db.VarChar(100) // 公开号
  pub_kind String? @db.VarChar(50) // 发布类型
  country  String? @db.VarChar(50)

  // 发明人信息
  inventors Json? // 发明人列表

  // 详细信息
  assignee    Json? // 受让人列表
  cpc         Json? // CPC分类号
  ipc         Json? // IPC分类号
  ipcr        Json? // IPCR分类号
  description String?   @db.Text
  app_date    DateTime?
  pub_date    DateTime?
  priority    Json? // 优先权信息

  // 附加链接
  preview_url  String? @db.VarChar(500)
  download_url String? @db.VarChar(500)

  create_time DateTime @default(now())
  update_time DateTime @updatedAt

  // 关联 - 用户行为
  searchHistory SearchHistory[]
  browseHistory BrowseHistory[]
  favorites     Favorite[]

  @@unique([source, source_id])
  @@index([source])
  @@index([year])
  @@index([country])
  @@index([app_num])
  @@index([pub_num])
  @@map("patents")
}

/// 搜索历史表 - 记录用户的搜索行为
model SearchHistory {
  id           String @id @default(uuid())
  user_id      String
  keyword      String @db.VarChar(200)
  search_type  String @db.VarChar(20) // paper, scholar, patent, comprehensive
  result_count Int?   @default(0)

  // 关联的结果（使用数据库 UUID）
  paper_id   String?
  scholar_id String?
  patent_id  String?

  deleted_status Int       @default(0) @map("deleted_status") // 删除状态: 0-正常, 1-已删除
  deleted_time   DateTime? @map("deleted_time") // 删除时间
  create_time    DateTime  @default(now())
  update_time    DateTime  @updatedAt

  user    User     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  paper   Paper?   @relation(fields: [paper_id], references: [id], onDelete: SetNull)
  scholar Scholar? @relation(fields: [scholar_id], references: [id], onDelete: SetNull)
  patent  Patent?  @relation(fields: [patent_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([create_time])
  @@index([user_id, search_type, create_time])
  @@index([user_id, deleted_status])
  @@map("search_history")
}

/// 浏览历史表 - 记录用户的浏览行为
model BrowseHistory {
  id          String @id @default(uuid())
  user_id     String
  browse_type String @db.VarChar(20) // paper, scholar, patent

  // 关联的资源（使用数据库 UUID）
  paper_id   String?
  scholar_id String?
  patent_id  String?

  create_time DateTime @default(now())
  update_time DateTime @updatedAt

  user    User     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  paper   Paper?   @relation(fields: [paper_id], references: [id], onDelete: SetNull)
  scholar Scholar? @relation(fields: [scholar_id], references: [id], onDelete: SetNull)
  patent  Patent?  @relation(fields: [patent_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([create_time])
  @@index([user_id, browse_type, create_time])
  @@index([user_id, browse_type, paper_id])
  @@index([user_id, browse_type, scholar_id])
  @@index([user_id, browse_type, patent_id])
  @@map("browse_history")
}

/// 收藏表 - 存储用户的收藏内容
model Favorite {
  id            String @id @default(uuid())
  user_id       String
  favorite_type String @db.VarChar(20) // paper, scholar, patent

  // 关联的资源（使用数据库 UUID）
  paper_id   String?
  scholar_id String?
  patent_id  String?

  create_time DateTime @default(now())
  update_time DateTime @updatedAt

  user    User     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  paper   Paper?   @relation(fields: [paper_id], references: [id], onDelete: SetNull)
  scholar Scholar? @relation(fields: [scholar_id], references: [id], onDelete: SetNull)
  patent  Patent?  @relation(fields: [patent_id], references: [id], onDelete: SetNull)

  @@unique([user_id, favorite_type, paper_id])
  @@unique([user_id, favorite_type, scholar_id])
  @@unique([user_id, favorite_type, patent_id])
  @@index([user_id])
  @@index([create_time])
  @@index([user_id, favorite_type, create_time])
  @@map("favorites")
}

// ==================== AI伴读功能相关模型 ====================

/// 用户上传论文表 - 存储用户上传的论文文件和解析后的内容
model UserUploadedPaper {
  id              String  @id @default(uuid())
  userId          String  @map("user_id")
  title           String  @db.VarChar(500)
  authors         String? @db.Text
  abstract        String? @db.Text
  keywords        String? @db.Text
  publicationYear Int?    @map("publication_year")
  source          String? @db.VarChar(100)
  doi             String? @db.VarChar(200)

  // 文件信息
  filePath String @map("file_path") @db.VarChar(500)
  fileName String @map("file_name") @db.VarChar(255)
  fileSize BigInt @map("file_size")
  fileType String @map("file_type") @db.VarChar(50)
  mimeType String @map("mime_type") @db.VarChar(100)

  // 解析状态
  parseStatus   String    @default("pending") @map("parse_status") @db.VarChar(20)
  parsedContent String?   @map("parsed_content") @db.LongText
  pageCount     Int?      @map("page_count")
  wordCount     Int?      @map("word_count")
  parseError    String?   @map("parse_error") @db.Text
  parsedAt      DateTime? @map("parsed_at")

  // 统计信息
  readCount         Int       @default(0) @map("read_count")
  conversationCount Int       @default(0) @map("conversation_count")
  annotationCount   Int       @default(0) @map("annotation_count")
  citationCount     Int       @default(0) @map("citation_count")
  lastReadAt        DateTime? @map("last_read_at")

  // 时间戳
  createTime DateTime  @default(now()) @map("create_time")
  updateTime DateTime  @updatedAt @map("update_time")
  deletedAt  DateTime? @map("deleted_at")

  // 关联
  user               User                 @relation(fields: [userId], references: [user_id], onDelete: Cascade)
  conversations      ChatConversation[]
  annotations        PaperAnnotation[]
  readingRecords     PaperReadingRecord[]
  messageAttachments MessageAttachment[]
  folderItems        FolderItem[]    // 文件夹关联

  @@index([userId])
  @@index([createTime])
  @@index([parseStatus])
  @@index([deletedAt])
  @@map("user_uploaded_papers")
}

/// 论文标注表 - 存储用户对论文的标注（高亮）
model PaperAnnotation {
  id              String @id @default(uuid())
  userId          String @map("user_id")
  uploadedPaperId String @map("uploaded_paper_id")

  annotationText String @map("annotation_text") @db.Text
  annotationType String @default("highlight") @map("annotation_type") @db.VarChar(20)
  color          String @default("yellow") @db.VarChar(20)

  pageNumber   Int?  @map("page_number")
  startOffset  Int   @map("start_offset")
  endOffset    Int   @map("end_offset")
  positionJson Json? @map("position_json") // 详细位置信息 (用于PDF坐标定位)

  note String? @db.Text
  tags Json? // 标签 (JSON数组)

  createTime DateTime  @default(now()) @map("create_time")
  updateTime DateTime  @updatedAt @map("update_time")
  deletedAt  DateTime? @map("deleted_at")

  // 关联
  user          User              @relation(fields: [userId], references: [user_id], onDelete: Cascade)
  uploadedPaper UserUploadedPaper @relation(fields: [uploadedPaperId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([uploadedPaperId])
  @@index([createTime])
  @@index([deletedAt])
  @@map("paper_annotations")
}

/// 阅读记录表 - 记录用户的阅读进度和行为
model PaperReadingRecord {
  id              String @id @default(uuid())
  userId          String @map("user_id")
  uploadedPaperId String @map("uploaded_paper_id")

  currentPage        Int     @default(1) @map("current_page")
  totalPages         Int?    @map("total_pages")
  scrollPosition     Int     @default(0) @map("scroll_position")
  progressPercentage Decimal @default(0) @map("progress_percentage") @db.Decimal(5, 2)

  readingDurationSeconds BigInt    @default(0) @map("reading_duration_seconds")
  sessionStartAt         DateTime? @map("session_start_at")
  sessionEndAt           DateTime? @map("session_end_at")

  annotationCreated Int @default(0) @map("annotation_created")
  citationCreated   Int @default(0) @map("citation_created")
  translationUsed   Int @default(0) @map("translation_used")
  aiQuestionAsked   Int @default(0) @map("ai_question_asked")

  createTime DateTime @default(now()) @map("create_time")
  updateTime DateTime @updatedAt @map("update_time")

  // 关联
  user          User              @relation(fields: [userId], references: [user_id], onDelete: Cascade)
  uploadedPaper UserUploadedPaper @relation(fields: [uploadedPaperId], references: [id], onDelete: Cascade)

  @@unique([userId, uploadedPaperId])
  @@index([userId])
  @@index([uploadedPaperId])
  @@index([updateTime])
  @@map("paper_reading_records")
}

/// 学者论文关联表 - 存储学者与论文的关联关系（来自 AMiner person/paper/relation 接口）
model ScholarPaper {
  id String @id @default(uuid())

  // 学者信息（使用 AMiner ID 作为关联键，避免 UUID 变化问题）
  scholar_aminer_id String @db.VarChar(200) // 学者的 AMiner ID

  // 论文信息
  paper_aminer_id String  @db.VarChar(200) // 论文的 AMiner ID
  title           String? @db.VarChar(500) // 论文标题
  title_zh        String? @db.VarChar(500) // 中文标题

  // 时间戳
  create_time DateTime @default(now())
  update_time DateTime @updatedAt

  // 唯一约束：同一学者的同一论文只存一条
  @@unique([scholar_aminer_id, paper_aminer_id])
  @@index([scholar_aminer_id])
  @@index([paper_aminer_id])
  @@map("scholar_papers")
}

/// 学者专利关联表 - 存储学者与专利的关联关系（来自 AMiner person/patent/relation 接口）
model ScholarPatentRelation {
  id String @id @default(uuid())

  // 学者信息（使用 AMiner ID 作为关联键，避免 UUID 变化问题）
  scholar_aminer_id String @db.VarChar(200) // 学者的 AMiner ID

  // 专利信息
  patent_aminer_id String  @db.VarChar(200) // 专利的 AMiner ID
  title            String? @db.VarChar(500) // 专利标题
  title_zh         String? @db.VarChar(500) // 中文标题

  // 时间戳
  create_time DateTime @default(now())
  update_time DateTime @updatedAt

  // 唯一约束：同一学者的同一专利只存一条
  @@unique([scholar_aminer_id, patent_aminer_id])
  @@index([scholar_aminer_id])
  @@index([patent_aminer_id])
  @@map("scholar_patents")
}

/// 全文传递请求记录表 - 存储用户的全文传递请求
model DocDeliveryRequest {
  id      String @id @default(uuid())
  user_id String @map("user_id")

  // 第三方任务信息
  task_id String @db.VarChar(100) // 第三方返回的任务ID

  // 关联的论文（可选）
  paper_id String? @map("paper_id")

  // 论文信息快照（请求时保存，避免论文数据变动影响）
  title            String  @db.VarChar(500)
  authors          Json?   // 作者列表
  publication_name String? @map("publication_name") @db.VarChar(255)
  publication_year Int?    @map("publication_year")
  abstract         String? @db.Text
  doi              String? @db.VarChar(200)
  tags             Json?   // 标签（如 CAS-4, SCIE）

  // 分类信息
  subject_category String? @map("subject_category") @db.VarChar(100) // 学科类别
  article_type     String? @map("article_type") @db.VarChar(50) // 文章类型

  // 状态信息
  // 0:查询失败 1:提交中 2:服务中 3:已上传 4:已下载 8:完成结束 9:无法完成结束
  status      Int     @default(1)
  status_text String? @map("status_text") @db.VarChar(50)

  // 全文信息
  fulltext_url  String? @map("fulltext_url") @db.VarChar(500) // 全文下载URL
  lib_attach_id String? @map("lib_attach_id") @db.VarChar(100) // 文献附件ID

  // 时间戳
  create_time    DateTime  @default(now()) @map("create_time")
  update_time    DateTime  @updatedAt @map("update_time")
  completed_time DateTime? @map("completed_time") // 完成时间

  // 关联
  user  User   @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  paper Paper? @relation(fields: [paper_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([task_id])
  @@index([status])
  @@index([create_time])
  @@map("doc_delivery_requests")
}

// ==================== 用户通知系统 ====================

model UserNotification {
  id                String    @id @default(uuid())
  user_id           String
  notification_type String    @db.VarChar(50) // doc_delivery | system | account
  title             String    @db.VarChar(255)
  content           String?   @db.Text
  is_read           Boolean   @default(false)
  // 关联数据（可选，用于跳转）
  related_type      String?   @db.VarChar(50) // paper | doc_delivery_request
  related_id        String?
  // 元数据
  metadata          String?   @db.Text // JSON 格式的额外数据
  create_time       DateTime  @default(now())
  read_time         DateTime?

  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([user_id, is_read])
  @@index([user_id, notification_type])
  @@index([create_time])
  @@map("user_notifications")
}
