{
  "openapi": "3.0.3",
  "info": {
    "title": "临港图书馆通用配置 API",
    "description": "临港图书馆系统的通用配置管理接口文档，提供配置的查询和更新功能",
    "version": "1.0.0",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3007",
      "description": "开发环境"
    },
    {
      "url": "https://api.lingang-library.com",
      "description": "生产环境"
    }
  ],
  "tags": [
    {
      "name": "通用配置",
      "description": "系统通用配置相关接口"
    }
  ],
  "paths": {
    "/api/common-config": {
      "get": {
        "tags": ["通用配置"],
        "summary": "获取配置列表",
        "description": "获取系统所有可用的通用配置列表。需要认证",
        "operationId": "getConfigList",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "获取成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConfigListResponse"
                }
              }
            }
          },
          "401": {
            "description": "未授权（token 无效或过期）",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "405": {
            "description": "方法不允许",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "501": {
            "description": "获取配置失败",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/common-config/{key}": {
      "get": {
        "tags": ["通用配置"],
        "summary": "查询单个配置",
        "description": "根据配置键名获取配置详细信息。需要认证",
        "operationId": "getConfigByKey",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "key",
            "in": "path",
            "required": true,
            "description": "配置键名",
            "schema": {
              "type": "string"
            },
            "example": "api_key"
          }
        ],
        "responses": {
          "200": {
            "description": "获取成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConfigResponse"
                }
              }
            }
          },
          "401": {
            "description": "未授权（token 无效或过期）",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "405": {
            "description": "方法不允许",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "501": {
            "description": "获取配置失败",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "警告响应（缺少配置键名）",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WarningResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": ["通用配置"],
        "summary": "更新配置",
        "description": "根据配置键名更新配置信息。需要认证",
        "operationId": "updateConfigByKey",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "key",
            "in": "path",
            "required": true,
            "description": "配置键名",
            "schema": {
              "type": "string"
            },
            "example": "api_key"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateConfigRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "更新成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "401": {
            "description": "未授权（token 无效或过期）",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "405": {
            "description": "方法不允许",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "501": {
            "description": "更新失败",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "警告响应（缺少配置键名）",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WarningResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT 认证 token，有效期7天"
      }
    },
    "schemas": {
      "ConfigItem": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string",
            "description": "配置标签/显示名称",
            "example": "API密钥"
          },
          "key": {
            "type": "string",
            "description": "配置键名（唯一标识）",
            "example": "api_key"
          },
          "value": {
            "type": "string",
            "description": "配置值",
            "example": "sk-xxxxxxxxxxxx"
          },
          "type": {
            "type": "string",
            "description": "配置类型",
            "example": "string"
          }
        }
      },
      "ConfigListResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "响应消息",
            "example": "获取成功"
          },
          "data": {
            "type": "array",
            "description": "配置列表",
            "items": {
              "$ref": "#/components/schemas/ConfigItem"
            }
          }
        }
      },
      "ConfigResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "响应消息",
            "example": "获取成功"
          },
          "data": {
            "$ref": "#/components/schemas/ConfigItem"
          }
        }
      },
      "UpdateConfigRequest": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string",
            "description": "配置标签/显示名称（可选）",
            "example": "API密钥"
          },
          "value": {
            "type": "string",
            "description": "配置值（可选）",
            "example": "sk-xxxxxxxxxxxx"
          },
          "type": {
            "type": "string",
            "description": "配置类型（可选）",
            "example": "string"
          }
        },
        "description": "至少提供一个字段进行更新"
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "成功消息",
            "example": "更新成功"
          },
          "data": {
            "type": "object",
            "description": "响应数据（可选）"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "错误消息",
            "example": "操作失败"
          }
        }
      },
      "WarningResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "警告消息",
            "example": "缺少配置键名"
          },
          "data": {
            "type": "object",
            "description": "附加数据（可选）"
          }
        }
      }
    }
  }
}
