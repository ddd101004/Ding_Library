        "operationId": "deletePaper",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "论文 ID",
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "删除成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "删除成功" }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/UnauthorizedError" },
          "503": { "$ref": "#/components/responses/WarningResponse" },
          "501": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/api/ai-reading/annotations": {
      "post": {
        "tags": ["标注管理"],
        "summary": "创建标注",
        "description": "为论文文本创建高亮标注",
