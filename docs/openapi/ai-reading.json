              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "获取成功" },
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/ReadingRecord" }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/UnauthorizedError" },
