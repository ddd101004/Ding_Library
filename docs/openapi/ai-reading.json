    "/api/ai-reading/reading-records/{paper_id}": {
      "get": {
        "tags": ["阅读记录"],
        "summary": "获取单篇论文阅读统计",
        "description": "获取指定论文的详细阅读统计",
        "operationId": "getPaperReadingRecord",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "paper_id",
            "in": "path",
            "required": true,
            "description": "论文 ID",
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "获取成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "获取成功" },
                    "data": { "$ref": "#/components/schemas/ReadingRecord" }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/UnauthorizedError" },
