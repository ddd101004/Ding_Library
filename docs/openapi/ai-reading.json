        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AnnotationCreateRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "创建成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "创建成功" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "string", "format": "uuid" }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/UnauthorizedError" },
          "503": { "$ref": "#/components/responses/WarningResponse" },
          "501": { "$ref": "#/components/responses/ServerError" }
        }
      },
      "get": {
        "tags": ["标注管理"],
        "summary": "获取论文的所有标注",
        "description": "获取指定论文的所有标注记录",
        "operationId": "getPaperAnnotations",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "uploaded_paper_id",
            "in": "query",
            "required": true,
            "description": "论文 ID",
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "获取成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "获取成功" },
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Annotation" }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/UnauthorizedError" },
          "501": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/api/ai-reading/annotations/{id}": {
      "put": {
