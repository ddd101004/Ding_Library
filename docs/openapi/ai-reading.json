    "/api/ai-reading/reading-records": {
      "get": {
        "tags": ["阅读记录"],
        "summary": "获取用户所有阅读记录",
        "description": "获取用户的所有论文阅读统计记录",
        "operationId": "getUserReadingRecords",
        "security": [{ "bearerAuth": [] }],
        "responses": {
