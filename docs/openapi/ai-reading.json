  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT 认证 token，有效期7天"
      }
    },
    "schemas": {
      "PaperConversation": {
        "type": "object",
        "properties": {
          "conversation_id": {
            "type": "string",
            "format": "uuid",
            "description": "对话 ID"
          },
          "title": {
            "type": "string",
            "description": "对话标题"
          },
          "conversation_type": {
            "type": "string",
            "enum": ["paper_reading"],
            "description": "对话类型"
          },
          "uploaded_paper_id": {
            "type": "string",
            "format": "uuid",
            "description": "关联论文 ID"
          },
          "message_count": {
            "type": "integer",
            "description": "消息总数"
          },
          "is_deep_think": {
            "type": "boolean",
            "description": "是否启用深度思考模式"
          },
          "is_pinned": {
            "type": "boolean",
            "description": "是否置顶"
          },
          "last_message_at": {
            "type": "string",
            "format": "date-time",
            "description": "最后消息时间"
          },
          "create_time": {
            "type": "string",
            "format": "date-time",
            "description": "创建时间"
          }
        }
      },
      "PaperConversationDetail": {
        "allOf": [
          { "$ref": "#/components/schemas/PaperConversation" },
          {
            "type": "object",
            "properties": {
              "paper": {
                "type": "object",
                "description": "关联论文信息",
                "properties": {
                  "id": { "type": "string", "format": "uuid" },
                  "title": { "type": "string" },
                  "authors": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "abstract": { "type": "string" },
                  "keywords": { "type": "string" }
                }
              }
            }
          }
        ]
      },
      "PaperMessage": {
        "type": "object",
        "properties": {
          "message_id": {
            "type": "string",
            "format": "uuid"
          },
          "role": {
            "type": "string",
            "enum": ["user", "assistant"],
            "description": "消息角色"
          },
          "content": {
            "type": "string",
            "description": "消息内容"
          },
          "message_type": {
            "type": "string",
            "enum": ["text", "analyze", "translate", "summarize", "explain"],
            "description": "消息类型"
          },
          "reasoning_content": {
            "type": "string",
            "nullable": true,
            "description": "推理过程（DeepSeek-R1）"
          },
          "context_text": {
            "type": "string",
            "nullable": true,
            "description": "引用的论文文本"
          },
          "context_range": {
            "type": "object",
            "nullable": true,
            "description": "文本位置信息"
          },
          "input_tokens": {
            "type": "integer",
            "description": "输入 tokens"
          },
          "output_tokens": {
            "type": "integer",
            "description": "输出 tokens"
          },
          "total_tokens": {
            "type": "integer",
            "description": "总 tokens"
          },
          "create_time": {
            "type": "string",
            "format": "date-time"
          },
          "has_multiple_versions": {
            "type": "boolean",
            "description": "是否有多个版本（仅 assistant 消息有效）。前端可根据此字段筛选需要查询版本详情的消息 ID，然后调用批量版本查询接口获取完整版本信息"
          }
        }
      },
      "UserPaper": {
        "type": "object",
        "description": "用户上传的论文（列表项）",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "title": { "type": "string", "nullable": true, "description": "论文标题" },
          "authors": {
            "type": "array",
            "items": { "type": "string" },
            "nullable": true,
            "description": "作者列表"
          },
          "file_name": { "type": "string", "description": "文件名" },
          "file_size": { "type": "integer", "description": "文件大小（字节）" },
          "file_type": { "type": "string", "description": "文件类型", "example": "pdf" },
          "parse_status": {
            "type": "string",
            "enum": ["pending", "parsing", "completed", "failed"],
            "description": "解析状态"
          },
          "page_count": { "type": "integer", "nullable": true, "description": "页数" },
          "word_count": { "type": "integer", "nullable": true, "description": "字数" },
          "read_count": { "type": "integer", "description": "阅读次数" },
          "conversation_count": { "type": "integer", "description": "对话次数" },
          "annotation_count": { "type": "integer", "description": "标注数量" },
          "citation_count": { "type": "integer", "description": "引用次数" },
          "last_read_at": { "type": "string", "format": "date-time", "nullable": true, "description": "最后阅读时间" },
          "create_time": { "type": "string", "format": "date-time", "description": "创建时间" }
        }
      },
      "UserPaperDetail": {
        "type": "object",
        "description": "用户上传的论文详情（包含 COS 访问信息）",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "title": { "type": "string", "nullable": true, "description": "论文标题" },
          "authors": {
            "type": "array",
            "items": { "type": "string" },
            "description": "作者列表"
          },
          "abstract": { "type": "string", "description": "摘要" },
          "keywords": {
            "type": "array",
            "items": { "type": "string" },
            "description": "关键词列表"
          },
          "publication_year": { "type": "integer", "nullable": true, "description": "发表年份" },
          "source": { "type": "string", "description": "来源" },
          "doi": { "type": "string", "description": "DOI" },
          "file_url": {
            "type": "string",
            "description": "COS 文件访问 URL（带签名，1小时有效）",
            "example": "https://bucket.cos.region.myqcloud.com/papers/..."
          },
          "cos_key": {
            "type": "string",
            "description": "COS 对象 key（供前端缓存使用）",
            "example": "papers/user123/1702345678_abc123.pdf"
          },
          "file_name": { "type": "string", "description": "文件名" },
          "file_size": { "type": "integer", "description": "文件大小（字节）" },
          "file_type": { "type": "string", "description": "文件类型" },
          "mime_type": { "type": "string", "description": "MIME 类型" },
          "parse_status": {
            "type": "string",
            "enum": ["pending", "parsing", "completed", "failed"],
            "description": "解析状态"
          },
          "page_count": { "type": "integer", "nullable": true, "description": "页数" },
          "word_count": { "type": "integer", "nullable": true, "description": "字数" },
          "parse_error": { "type": "string", "description": "解析错误信息" },
          "parsed_at": { "type": "string", "format": "date-time", "nullable": true, "description": "解析完成时间" },
          "read_count": { "type": "integer", "description": "阅读次数" },
          "conversation_count": { "type": "integer", "description": "对话次数" },
          "annotation_count": { "type": "integer", "description": "标注数量" },
          "citation_count": { "type": "integer", "description": "引用次数" },
          "last_read_at": { "type": "string", "format": "date-time", "description": "最后阅读时间" },
          "create_time": { "type": "string", "format": "date-time", "description": "创建时间" },
          "update_time": { "type": "string", "format": "date-time", "description": "更新时间" }
        }
      },
      "AnnotationCreateRequest": {
        "type": "object",
        "required": ["uploaded_paper_id", "annotation_text", "start_offset", "end_offset"],
        "properties": {
          "uploaded_paper_id": {
            "type": "string",
            "format": "uuid",
            "description": "论文 ID"
          },
          "annotation_text": {
            "type": "string",
            "description": "标注的文本内容"
          },
          "annotation_type": {
            "type": "string",
            "default": "highlight",
            "enum": ["highlight", "underline", "note"],
            "description": "标注类型"
          },
          "start_offset": {
            "type": "integer",
            "description": "起始位置偏移量"
          },
          "end_offset": {
            "type": "integer",
            "description": "结束位置偏移量"
          },
          "page_number": {
            "type": "integer",
            "description": "页码（可选）"
          },
          "position_json": {
            "type": "string",
            "description": "PDF 阅读器专用位置数据（JSON字符串，可选）"
          },
          "note": {
            "type": "string",
            "description": "备注"
          },
          "tags": {
            "type": "string",
            "description": "标签（逗号分隔）"
          },
          "color": {
            "type": "string",
            "default": "yellow",
            "description": "高亮颜色"
          }
        }
      },
      "Annotation": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "uploaded_paper_id": { "type": "string", "format": "uuid", "description": "论文 ID" },
          "annotation_text": { "type": "string", "description": "标注文本" },
          "annotation_type": { "type": "string", "description": "标注类型" },
          "color": { "type": "string", "description": "颜色" },
          "page_number": { "type": "integer", "description": "页码" },
          "start_offset": { "type": "integer", "description": "起始位置偏移量" },
          "end_offset": { "type": "integer", "description": "结束位置偏移量" },
          "position_json": { "type": "string", "nullable": true, "description": "PDF 阅读器位置数据" },
          "note": { "type": "string", "description": "备注" },
          "tags": { "type": "string", "nullable": true, "description": "标签" },
          "create_time": { "type": "string", "format": "date-time" },
          "update_time": { "type": "string", "format": "date-time" }
        }
      },
      "ReadingRecord": {
        "type": "object",
        "properties": {
          "uploaded_paper_id": {
            "type": "string",
            "format": "uuid",
            "description": "论文 ID"
          },
          "paper_title": {
            "type": "string",
            "description": "论文标题"
          },
          "total_reading_time": {
            "type": "integer",
            "description": "总阅读时长（秒）"
          },
          "annotation_count": {
            "type": "integer",
            "description": "标注数量"
          },
          "translation_used": {
            "type": "integer",
            "description": "翻译使用次数"
          },
          "ai_question_asked": {
            "type": "integer",
            "description": "AI 提问次数"
          },
          "last_read_at": {
            "type": "string",
            "format": "date-time",
            "description": "最后阅读时间"
          }
        }
      }
    },
    "responses": {
      "UnauthorizedError": {
        "description": "未授权 - Token 无效或已过期",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "type": "string",
                  "example": "未授权"
                }
              }
            }
          }
        }
      },
      "WarningResponse": {
        "description": "警告响应 - 参数验证失败或资源不存在",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "type": "string",
                  "example": "参数验证失败"
                },
                "data": {
                  "type": "object",
                  "description": "详细错误信息"
                }
              }
            }
          }
        }
      },
      "ServerError": {
        "description": "服务器错误",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "type": "string",
                  "example": "服务器错误"
                }
              }
            }
          }
        }
      }
    }
  }
}
