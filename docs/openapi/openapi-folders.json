  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT认证，格式：Bearer {token}"
      }
    },
    "schemas": {
      "Folder": {
        "type": "object",
        "properties": {
          "folder_id": {
            "type": "string",
            "format": "uuid"
          },
          "user_id": {
            "type": "string",
            "format": "uuid"
          },
          "folder_name": {
            "type": "string"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "color": {
            "type": "string",
            "nullable": true
          },
          "cover_image": {
            "type": "string",
            "nullable": true,
            "description": "封面图 COS key"
          },
          "cover_image_url": {
            "type": "string",
            "nullable": true,
            "description": "封面图签名 URL（7天有效期）"
          },
          "sort_order": {
            "type": "integer"
          },
          "item_count": {
            "type": "integer",
            "description": "文件夹内内容数量"
          },
          "create_time": {
            "type": "string",
            "format": "date-time"
          },
          "update_time": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "FolderPaperItem": {
        "type": "object",
        "description": "文件夹内的论文项（paper 或 uploaded_paper 类型）",
        "properties": {
          "item_id": {
            "type": "string",
            "format": "uuid"
          },
          "item_type": {
            "type": "string",
            "enum": ["paper", "uploaded_paper"],
            "description": "paper: 第三方论文, uploaded_paper: 用户上传论文"
          },
          "paper_id": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string"
          },
          "authors": {
            "type": ["string", "array", "null"],
            "description": "作者信息"
          },
          "publication_name": {
            "type": "string",
            "nullable": true
          },
          "year": {
            "type": "integer",
            "nullable": true
          },
          "abstract": {
            "type": "string",
            "nullable": true
          },
          "has_fulltext": {
            "type": "boolean"
          },
          "file_type": {
            "type": "string",
            "nullable": true,
            "description": "仅 uploaded_paper 类型有此字段"
          },
          "parse_status": {
            "type": "string",
            "nullable": true,
            "description": "仅 uploaded_paper 类型有此字段"
          },
          "added_at": {
            "type": "string",
            "format": "date-time"
          },
          "notes": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "FolderConversationItem": {
        "type": "object",
        "description": "文件夹内的对话项",
        "properties": {
          "item_id": {
            "type": "string",
            "format": "uuid"
          },
          "item_type": {
            "type": "string",
            "enum": ["conversation"]
          },
          "conversation_id": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string"
          },
          "conversation_type": {
            "type": "string",
            "description": "对话类型：general, paper_reading"
          },
          "message_count": {
            "type": "integer"
          },
          "last_message_at": {
            "type": "string",
            "format": "date-time"
          },
          "added_at": {
            "type": "string",
            "format": "date-time"
          },
          "notes": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 200
          },
          "message": {
            "type": "string",
            "example": "操作成功"
          },
          "data": {
            "type": "object"
          }
        }
      }
    }
  }
}
