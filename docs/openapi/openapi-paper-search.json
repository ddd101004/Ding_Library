{
  "openapi": "3.0.3",
  "info": {
    "title": "学术搜索 API",
    "description": "学术搜索系统 - 支持 AMiner、EBSCO、Wanfang、本地数据库",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3007",
      "description": "本地开发环境"
    },
    {
      "url": "https://api.example.com",
      "description": "生产环境"
    }
  ],
  "tags": [
    {
      "name": "AMiner搜索",
      "description": "学术搜索相关接口"
    }
  ],
  "paths": {
    "/api/search/papers": {
      "post": {
        "tags": ["AMiner搜索"],
        "summary": "论文搜索（多数据源）",
        "description": "搜索学术论文，支持四种数据源：AMiner API（默认）、EBSCO API、Wanfang、本地数据库。所有数据源统一返回 items 数组格式。",
        "operationId": "searchPapers",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["keyword"],
                "properties": {
                  "keyword": {
                    "type": "string",
                    "description": "搜索关键词",
                    "example": "machine learning"
                  },
                  "source": {
                    "type": "string",
                    "enum": ["aminer", "ebsco", "wanfang", "local"],
                    "default": "aminer",
                    "description": "数据源：aminer-AMiner API（默认）, ebsco-EBSCO API, wanfang-万方数据, local-本地数据库"
                  },
                  "page": {
                    "type": "integer",
                    "minimum": 1,
                    "default": 1,
                    "description": "页码（从1开始）"
                  },
                  "size": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 100,
                    "default": 10,
                    "description": "每页数量（已废弃，请使用 page_size）"
                  },
                  "page_size": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 100,
                    "default": 20,
                    "description": "每页数量"
                  },
                  "search_type": {
                    "type": "string",
                    "enum": ["title", "keyword", "abstract", "author", "org", "venue"],
                    "default": "title",
                    "description": "搜索类型：title-标题, keyword-关键词, abstract-摘要, author-作者, org-机构, venue-期刊"
                  },
                  "order": {
                    "type": "string",
                    "enum": ["year", "n_citation"],
                    "description": "排序方式（AMiner）：year-按年份, n_citation-按引用数"
                  },
                  "sort": {
                    "type": "string",
                    "enum": ["relevance", "date"],
                    "default": "relevance",
                    "description": "排序方式（EBSCO/Local）：relevance-相关度, date-日期"
                  },
                  "year_from": {
                    "type": "integer",
                    "description": "起始年份（仅 AMiner）",
                    "example": 2020
                  },
                  "year_to": {
                    "type": "integer",
                    "description": "结束年份（仅 AMiner）",
                    "example": 2024
                  },
                  "field_code": {
                    "type": "string",
                    "description": "搜索字段代码（仅 EBSCO）"
                  },
                  "limiters": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    },
                    "description": "限制器（仅 EBSCO）"
                  },
                  "expanders": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "扩展器（仅 EBSCO）"
                  },
                  "facet_filters": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    },
                    "description": "分面过滤器（仅 EBSCO）"
                  },
                  "view": {
                    "type": "string",
                    "enum": ["brief", "detailed"],
                    "default": "brief",
                    "description": "结果视图（仅 EBSCO）"
                  },
                  "search_mode": {
                    "type": "string",
                    "enum": ["all", "any", "smart"],
                    "default": "all",
                    "description": "搜索模式（仅 EBSCO）"
                  },
                  "highlight": {
                    "type": "boolean",
                    "default": true,
                    "description": "是否高亮显示（仅 EBSCO）"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "搜索成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 200
                    },
                    "message": {
                      "type": "string",
                      "example": "搜索成功"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "total": {
                          "type": "integer",
                          "description": "总结果数"
                        },
                        "page": {
                          "type": "integer",
                          "description": "当前页码"
                        },
                        "page_size": {
                          "type": "integer",
                          "description": "每页数量"
                        },
                        "total_pages": {
                          "type": "integer",
                          "description": "总页数"
                        },
                        "source": {
                          "type": "string",
                          "enum": ["aminer", "ebsco", "wanfang", "local"],
                          "description": "数据源标识"
                        },
                        "items": {
                          "type": "array",
                          "description": "论文列表（统一格式）",
                          "items": {
                            "$ref": "#/components/schemas/PaperItem"
                          }
                        },
                        "search_time": {
                          "type": "number",
                          "description": "搜索耗时（秒，仅 EBSCO 返回）"
                        },
                        "facets": {
                          "type": "array",
                          "description": "分面数据（仅 EBSCO 返回）",
                          "items": {
                            "type": "object"
                          }
                        },
                        "databases": {
                          "type": "array",
                          "description": "数据库信息（仅 EBSCO 返回）",
                          "items": {
                            "type": "object"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "503": {
            "$ref": "#/components/responses/WarningResponse"
          },
          "501": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/api/search/scholars": {
      "post": {
        "tags": ["AMiner搜索"],
        "summary": "学者搜索",
        "description": "搜索学者信息，支持按姓名、机构搜索，可按引用数或姓名排序",
        "operationId": "searchScholars",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "学者姓名",
                    "example": "张三"
                  },
                  "org": {
                    "type": "string",
                    "description": "机构名称",
                    "example": "清华大学"
                  },
                  "offset": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0,
                    "description": "偏移量（从0开始）"
                  },
                  "size": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 100,
                    "default": 10,
                    "description": "返回数量"
                  },
                  "order": {
                    "type": "string",
                    "enum": ["n_citation", "name"],
                    "description": "排序方式：n_citation-按引用数, name-按姓名"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "搜索成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 200
                    },
                    "message": {
                      "type": "string",
                      "example": "搜索成功"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "total": {
                          "type": "integer"
                        },
                        "offset": {
                          "type": "integer"
                        },
                        "size": {
                          "type": "integer"
                        },
                        "items": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/ScholarItem"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/api/search/patents": {
      "post": {
        "tags": ["AMiner搜索"],
        "summary": "专利搜索",
        "description": "搜索专利信息，支持关键词搜索",
        "operationId": "searchPatents",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["keyword"],
                "properties": {
                  "keyword": {
                    "type": "string",
                    "description": "搜索关键词",
                    "example": "人工智能"
                  },
                  "page": {
                    "type": "integer",
                    "minimum": 1,
                    "default": 1,
                    "description": "页码（从1开始）"
                  },
                  "size": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 100,
                    "default": 10,
                    "description": "每页数量"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "搜索成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 200
                    },
                    "message": {
                      "type": "string",
                      "example": "搜索成功"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "total": {
                          "type": "integer"
                        },
                        "page": {
                          "type": "integer"
                        },
                        "size": {
                          "type": "integer"
                        },
                        "totalPages": {
                          "type": "integer"
                        },
                        "items": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/PatentItem"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/api/search/comprehensive": {
      "post": {
        "tags": ["AMiner搜索"],
        "summary": "综合搜索",
        "description": "同时搜索四类内容：中文论文（万方）、外文论文（EBSCO）、学者（AMiner）、专利（AMiner），返回混合结果",
        "operationId": "comprehensiveSearch",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["keyword"],
                "properties": {
                  "keyword": {
                    "type": "string",
                    "description": "搜索关键词",
                    "example": "deep learning"
                  },
                  "page_size": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 20,
                    "default": 5,
                    "description": "每类返回数量"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "搜索成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 200
                    },
                    "message": {
                      "type": "string",
                      "example": "搜索成功"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "keyword": {
                          "type": "string",
                          "description": "搜索关键词"
                        },
                        "papers_zh": {
                          "type": "object",
                          "description": "中文发现（万方数据源）",
                          "properties": {
                            "total": {
                              "type": "integer",
                              "description": "中文论文总数"
                            },
                            "page": {
                              "type": "integer",
                              "description": "当前页码（综合搜索固定为1）"
                            },
                            "page_size": {
                              "type": "integer",
                              "description": "每页数量"
                            },
                            "total_pages": {
                              "type": "integer",
                              "description": "总页数"
                            },
                            "source": {
                              "type": "string",
                              "enum": ["wanfang"],
                              "description": "数据源标识"
                            },
                            "items": {
                              "type": "array",
                              "description": "中文论文列表",
                              "items": {
                                "$ref": "#/components/schemas/WanfangPaperItem"
                              }
                            }
                          }
                        },
                        "papers_en": {
                          "type": "object",
                          "description": "外文发现（EBSCO数据源）",
                          "properties": {
                            "total": {
                              "type": "integer",
                              "description": "外文论文总数"
                            },
                            "page": {
                              "type": "integer",
                              "description": "当前页码（综合搜索固定为1）"
                            },
                            "page_size": {
                              "type": "integer",
                              "description": "每页数量"
                            },
                            "total_pages": {
                              "type": "integer",
                              "description": "总页数"
                            },
                            "source": {
                              "type": "string",
                              "enum": ["ebsco"],
                              "description": "数据源标识"
                            },
                            "items": {
                              "type": "array",
                              "description": "外文论文列表",
                              "items": {
                                "$ref": "#/components/schemas/PaperItem"
                              }
                            }
                          }
                        },
                        "scholars": {
                          "type": "object",
                          "description": "学者（AMiner数据源）",
                          "properties": {
                            "total": {
                              "type": "integer",
                              "description": "学者总数"
                            },
                            "page": {
                              "type": "integer",
                              "description": "当前页码（综合搜索固定为1）"
                            },
                            "page_size": {
                              "type": "integer",
                              "description": "每页数量"
                            },
                            "total_pages": {
                              "type": "integer",
                              "description": "总页数"
                            },
                            "source": {
                              "type": "string",
                              "enum": ["aminer"],
                              "description": "数据源标识"
                            },
                            "items": {
                              "type": "array",
                              "description": "学者列表",
                              "items": {
                                "$ref": "#/components/schemas/ScholarItem"
                              }
                            }
                          }
                        },
                        "patents": {
                          "type": "object",
                          "description": "专利（AMiner数据源）",
                          "properties": {
                            "total": {
                              "type": "integer",
                              "description": "专利总数"
                            },
                            "page": {
                              "type": "integer",
                              "description": "当前页码（综合搜索固定为1）"
                            },
                            "page_size": {
                              "type": "integer",
                              "description": "每页数量"
                            },
                            "total_pages": {
                              "type": "integer",
                              "description": "总页数"
                            },
                            "source": {
                              "type": "string",
                              "enum": ["aminer"],
                              "description": "数据源标识"
                            },
                            "items": {
                              "type": "array",
                              "description": "专利列表",
                              "items": {
                                "$ref": "#/components/schemas/PatentItem"
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/api/search/statistics": {
      "get": {
        "tags": ["AMiner搜索"],
        "summary": "搜索统计",
        "description": "获取搜索结果统计，用于首页标签显示",
        "operationId": "getSearchStatistics",
        "parameters": [
          {
            "name": "keyword",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "搜索关键词",
            "example": "AI"
          }
        ],
        "responses": {
          "200": {
            "description": "获取成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 200
                    },
                    "message": {
                      "type": "string",
                      "example": "获取成功"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "papers_zh": {
                          "type": "integer",
                          "description": "中文论文数量"
                        },
                        "papers_en": {
                          "type": "integer",
                          "description": "英文论文数量"
                        },
                        "papers_total": {
                          "type": "integer",
                          "description": "论文总数"
                        },
                        "patents": {
                          "type": "integer",
                          "description": "专利数量"
                        },
                        "scholars": {
                          "type": "integer",
                          "description": "学者数量"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/api/search/related-tags": {
      "get": {
        "tags": ["AMiner搜索"],
        "summary": "相关标签",
        "description": "获取搜索关键词的相关标签（关键词、期刊、作者、机构），用于标签云展示",
        "operationId": "getRelatedTags",
        "parameters": [
          {
            "name": "keyword",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "搜索关键词",
            "example": "neural network"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 20
            },
            "description": "返回标签数量"
          }
        ],
        "responses": {
          "200": {
            "description": "获取成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 200
                    },
                    "message": {
                      "type": "string",
                      "example": "获取成功"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "keyword": {
                          "type": "string"
                        },
                        "tags": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "text": {
                                "type": "string",
                                "description": "标签文本"
                              },
                              "count": {
                                "type": "integer",
                                "description": "出现次数"
                              },
                              "type": {
                                "type": "string",
                                "enum": ["keyword", "venue", "author", "org"],
                                "description": "标签类型"
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "PaperItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "AMiner 论文 ID"
          },
          "aminer_id": {
            "type": "string",
            "description": "AMiner 论文 ID（同 id）"
          },
          "title": {
            "type": "string",
            "description": "论文标题"
          },
          "title_zh": {
            "type": "string",
            "description": "中文标题"
          },
          "abstract": {
            "type": "string",
            "description": "摘要"
          },
          "doi": {
            "type": "string",
            "description": "DOI"
          },
          "year": {
            "type": "integer",
            "description": "年份"
          },
          "authors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "name_zh": {
                  "type": "string"
                },
                "org": {
                  "type": "string"
                },
                "org_zh": {
                  "type": "string"
                }
              }
            }
          },
          "venue": {
            "type": "object",
            "properties": {
              "raw": {
                "type": "string"
              },
              "raw_zh": {
                "type": "string"
              },
              "t": {
                "type": "string"
              }
            }
          },
          "n_citation": {
            "type": "integer",
            "description": "引用数"
          },
          "isFavorited": {
            "type": "boolean",
            "description": "是否已收藏（仅登录用户返回）"
          }
        }
      },
      "ScholarItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "唯一标识（数据库 UUID 或 AMiner ID）"
          },
          "source": {
            "type": "string",
            "enum": ["aminer"],
            "description": "数据源标识"
          },
          "source_id": {
            "type": "string",
            "description": "源系统 ID（AMiner 学者 ID）"
          },
          "name": {
            "type": "string",
            "description": "姓名"
          },
          "name_zh": {
            "type": "string",
            "description": "中文姓名"
          },
          "org": {
            "type": "string",
            "description": "机构"
          },
          "org_zh": {
            "type": "string",
            "description": "中文机构"
          },
          "orgs": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "机构列表"
          },
          "org_zhs": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "中文机构列表"
          },
          "position": {
            "type": "string",
            "description": "职位"
          },
          "interests": {
            "type": "array",
            "items": {
              "type": "string"
            },
