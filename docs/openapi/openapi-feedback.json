{
  "openapi": "3.0.3",
  "info": {
    "title": "临港图书馆 - 反馈管理 API",
    "description": "消息反馈管理接口，包括创建反馈和查询反馈统计",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3007",
      "description": "本地开发环境"
    },
    {
      "url": "https://api.lingang-library.com",
      "description": "生产环境"
    }
  ],
  "tags": [
    {
      "name": "反馈管理",
      "description": "消息反馈的提交和统计"
    }
  ],
  "paths": {
    "/api/chat/feedback": {
      "post": {
        "tags": [
          "反馈管理"
        ],
        "summary": "提交反馈",
        "description": "为消息提交反馈（点赞、点踩、复制、重新生成等）",
        "operationId": "submitFeedback",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "message_id",
                  "feedback_type"
                ],
                "properties": {
                  "message_id": {
                    "type": "string",
                    "format": "uuid"
                  },
                  "feedback_type": {
                    "type": "string",
                    "enum": [
                      "like",
                      "dislike",
                      "copy",
                      "regenerate"
                    ],
                    "description": "反馈类型"
                  },
                  "feedback_content": {
                    "type": "string",
                    "description": "反馈内容（可选）"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "提交成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/chat/feedback/stats": {
      "get": {
        "tags": [
          "反馈管理"
        ],
        "summary": "获取反馈统计",
        "description": "获取指定会话的反馈统计信息",
        "operationId": "getFeedbackStats",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "conversation_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "获取成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "stats": {
                          "type": "object",
                          "properties": {
                            "like_count": {
                              "type": "integer"
                            },
                            "dislike_count": {
                              "type": "integer"
                            },
                            "copy_count": {
                              "type": "integer"
                            },
                            "regenerate_count": {
                              "type": "integer"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT认证，格式：Bearer {token}"
      }
    },
    "schemas": {
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "操作成功"
          },
          "data": {
            "type": "object"
          }
        }
      }
    }
  }
}
